# Memoora Microservice Environment Variables
# Copy this file to .env and fill in your actual values

# Server Configuration
NODE_ENV=development
PORT=5000
BASE_URL=http://localhost:5000

# Twilio Configuration
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# Phone Numbers
MY_PHONE_NUMBER=+1234567890

# OpenAI Configuration (if using AI features)
OPENAI_API_KEY=your_openai_api_key_here

# Security
CORS_ORIGIN=http://localhost:3000
API_KEY=your_api_key_here
# For multiple API keys, separate with commas
API_KEYS=key1,key2,key3
# Blocked phone numbers (separate with commas)
BLOCKED_NUMBERS=+1234567890,+0987654321

# Redis Configuration (optional, for distributed rate limiting)
REDIS_URL=redis://localhost:6379

# Recording Storage
RECORDINGS_PATH=./recordings
MAX_RECORDING_DURATION=120

# Rate Limiting
MAX_CALLS_PER_HOUR=10
MAX_REQUESTS_PER_HOUR=100 